\newcommand{\duchasetup}[1]{\pgfkeys{/ducha,#1}}

\newcommand{\duchaprinttextfield}[2]{%
	\ifstrempty{#2}{}{%
		\par\noindent\textbf{#1:} #2\par
	}%
}

\newcommand{\duchaprintlinkfield}[3]{%
	\ifstrempty{#2}{%
		\ifstrempty{#3}{}{%
			\par\noindent\textbf{#1:} \url{#3}\par
		}%
	}{%
		\par\noindent\textbf{#1:} %
		\ifstrempty{#3}{#2}{\href{#3}{#2}}%
		\par
	}%
}

\newcommand{\printduchametadata}{%
	\begingroup
	\par\medskip
	\noindent\textbf{Document Metadata}\par
	\smallskip
	\small
	\duchaprinttextfield{Version}{\duchaversionlabel}
	\duchaprintlinkfield{License}{\duchalicense}{\duchalicenseurl}
	\duchaprinttextfield{Copyright}{\duchacopyright}
	\duchaprintlinkfield{Code}{\duchacode}{\duchacodeurl}
	\duchaprintlinkfield{Data}{\duchadata}{\duchadataurl}
	\duchaprintlinkfield{Project}{\duchaproject}{\duchaprojecturl}
	\duchaprintlinkfield{Preprint}{\duchapreprint}{\duchapreprinturl}
	\ifstrempty{\duchadoi}{}{%
		\par\noindent\textbf{DOI:} \href{https://doi.org/\duchadoi}{\duchadoi}\par
	}
	\duchaprinttextfield{Note}{\duchanote}
	\par\medskip
	\endgroup
}

